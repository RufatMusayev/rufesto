# REAL / PRODUCTION stack  ->  docker project  r_rufesto  ->  rufesto.com
# Deploy: docker compose -p r_rufesto --env-file .env.prod up -d --build
# Copy to .env.prod on the server and fill the real secret values.

WEB_PORT=8090

# Cloudflare Tunnel must route these hostnames to localhost:8090
CORS_ORIGIN=https://rufesto.com,https://www.rufesto.com,https://resto.rufesto.com

# Supabase (build-time, embedded in the client bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (runtime, server-side service role — NEVER commit the real value)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
