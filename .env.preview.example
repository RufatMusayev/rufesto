# PREVIEW / TEST stack  ->  docker project  p_rufesto  ->  rufat-server.com
# Deploy: docker compose -p p_rufesto --env-file .env.preview up -d --build
# Copy to .env.preview on the server and fill the real secret values.

WEB_PORT=8080

# Cloudflare Tunnel must route these hostnames to localhost:8080
CORS_ORIGIN=https://rufat-server.com,https://www.rufat-server.com,https://resto.rufat-server.com

# Supabase (build-time, embedded in the client bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (runtime, server-side service role — NEVER commit the real value)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
